# Groq API Configuration (Mandatory)
# Get a key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Database Configuration (Optional, defaults to SQLite local database)
# For PostgreSQL: postgresql://username:password@localhost:5432/hcp_crm
# DATABASE_URL=sqlite:///./hcp_crm.db

# LLM Model Configuration
# Primary: gemma2-9b-it
# Alternative: llama-3.3-70b-versatile
LLM_MODEL=gemma2-9b-it
PORT=8000
HOST=0.0.0.0
